# Turso (libSQL) — create at https://turso.tech
# After: turso db create the-nook
#         turso db show the-nook --url      → TURSO_DATABASE_URL
#         turso db tokens create the-nook   → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Gmail SMTP for booking notifications. If any of GMAIL_USER /
# GMAIL_APP_PASSWORD / ADMIN_EMAIL is missing, email is silently disabled
# (bookings still succeed). The Gmail account must have 2-Step Verification
# enabled; create an App Password at https://myaccount.google.com/apppasswords
# and paste the 16-char value (spaces are stripped) into GMAIL_APP_PASSWORD.
GMAIL_USER=yourbookings@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=admin@yourdomain.com

# Optional. Defaults to GMAIL_USER. Use this if you've configured a
# "Send mail as" alias in Gmail and want emails to appear from that address.
# EMAIL_FROM="The Nook <bookings@yourdomain.com>"

# Used to build manage links inside emails. Must be the public origin
# (no trailing slash). Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
